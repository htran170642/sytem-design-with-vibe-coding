# AIVA Local Development Environment
# This is auto-generated for local development
# Customize as needed

# Application
APP_NAME=AIVA
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-change-this-in-production
API_KEY=your-api-key-here

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000"]
CORS_ALLOW_CREDENTIALS=true

# OpenAI (You need to add your actual key)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Database (Local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://aiva:aiva@localhost:5432/aiva_dev
DATABASE_ECHO=true
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis (Local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Cache
CACHE_TTL=3600
CACHE_ENABLED=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# Qdrant (Local)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=aiva_documents_dev
QDRANT_VECTOR_SIZE=1536

# Document Processing
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=["pdf","txt","docx","md"]
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
LOG_FORMAT=json
LOG_FILE=./logs/aiva.log
LOG_ROTATION="1 day"
LOG_RETENTION="30 days"

# Features
ENABLE_DOCS=true
ENABLE_RAG=true
ENABLE_BACKGROUND_JOBS=true
ENABLE_CACHING=true

# Flower
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin