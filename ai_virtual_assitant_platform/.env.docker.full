# AIVA Docker Environment — Full Stack
# Copy to .env before running: cp .env.docker.full .env
# Replace CHANGE_ME values before use.

# Application
APP_NAME=AIVA
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Security (CHANGE THESE!)
SECRET_KEY=CHANGE_ME_use_a_long_random_string
API_KEY=CHANGE_ME_use_32_hex_chars

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# OpenAI (required)
OPENAI_API_KEY=CHANGE_ME_your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Database — Docker service name "postgres"
DATABASE_URL=postgresql+asyncpg://aiva:aiva_password@postgres:5432/aiva
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis — Docker service name "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# Qdrant — Docker service name "qdrant"
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=aiva_documents
QDRANT_VECTOR_SIZE=1536

# Cache
CACHE_TTL=3600
CACHE_ENABLED=true
CACHE_AI_RESPONSE_TTL=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Document Processing
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=["pdf","txt","docx","md"]
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
LOG_FORMAT=json
LOG_FILE=/app/logs/aiva.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# Features
ENABLE_DOCS=true
ENABLE_RAG=true
ENABLE_BACKGROUND_JOBS=true
ENABLE_CACHING=true

# Flower
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:CHANGE_ME_flower_password
