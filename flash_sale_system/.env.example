# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://flash_sale:flash_sale@localhost:5432/flash_sale

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Flash sale config
STOCK_KEY_PREFIX=stock
IDEMPOTENCY_KEY_PREFIX=idempotency
IDEMPOTENCY_TTL_SECONDS=86400
ORDERS_STREAM=orders

# Rate limiting
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=100000

# Environment
ENV=development
LOG_LEVEL=INFO
