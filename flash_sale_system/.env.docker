# Docker-compose environment defaults.
# Override sensitive values via secrets manager in production.

ENV=development
LOG_LEVEL=INFO

# Flash sale config
STOCK_KEY_PREFIX=stock
IDEMPOTENCY_KEY_PREFIX=idempotency
IDEMPOTENCY_TTL_SECONDS=86400
ORDERS_STREAM=orders
ORDERS_CONSUMER_GROUP=order-workers
DLQ_STREAM=orders.dlq
STREAM_MAX_LEN=1000000
STREAM_CLAIM_MIN_IDLE_MS=30000

# Rate limiting
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=100000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
